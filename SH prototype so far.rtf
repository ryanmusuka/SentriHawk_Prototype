function selectTenant(tenantName, element) \{\
    // 1. Flash the box orange\
    element.classList.add('selected-flash');\
    \
    // 2. Wait 250ms for the visual effect, then execute\
    setTimeout(() => \{\
        closeTenantGrid();\
