    \
    allGuardViews.forEach(id => \{\
        const el = document.getElementById(id);\
        if (el) \{\
            el.classList.add('view-hidden');\
            el.classList.remove('view-active');\
        \}\
    \});\
\
    // 3. Show the requested view\
